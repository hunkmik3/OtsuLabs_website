{
  "name": "otsulabs-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:cms": "node --test --import tsx tests/cms/**/*.test.ts",
    "cms:migrate:postgres": "node --import tsx scripts/cms/migrate-postgres.ts",
